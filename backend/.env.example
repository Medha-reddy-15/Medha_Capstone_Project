# Port for the backend server to listen on
PORT=8000

# ── Primary: Groq — Meta-Llama 4 Scout 17B 16E Instruct
# Sign up at https://console.groq.com → API Keys
# Models: meta-llama/llama-4-scout-17b-16e-instruct
GROQ_API_KEY=gsk_...
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Secondary: Moondream (legacy, simpler queries only)
# Sign up at https://moondream.ai/me/api-keys
MOONDREAM_API_KEY=your-moondream-api-key

# ── Fallback: Claude (used when all above are absent or fail)
# Sign up at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
